# Koach AI Hub - API Keys
# Copy this to .env and fill in your keys

# Required: At least one provider
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional providers
XAI_API_KEY=xai-...
VENICE_API_KEY=...
GEMINI_API_KEY=...

# Security
HUB_API_SECRET=your-random-secret-here

# CORS (comma-separated origins, empty = allow all)
ALLOWED_ORIGINS=
